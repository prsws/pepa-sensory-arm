[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    venv,
    .mypy_cache
per-file-ignores =
    # Verbatim, field-tested default system prompt content - do not reflow.
    custom_components/pepa_sensory_arm/const.py:E501
    # pyscript injects hass/log/state/service and the trigger decorators as
    # runtime globals; flake8 can't see them statically.
    custom_components/pyscript/*.py:F821
